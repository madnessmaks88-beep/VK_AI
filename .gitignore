# База данных с историей переписки пользователей ВК - это ЧУЖИЕ ПЕРСОНАЛЬНЫЕ
# ДАННЫЕ (переписка реальных людей), ни в коем случае нельзя коммитить,
# даже если репозиторий приватный
bot_history.db
*.db
*.sqlite
*.sqlite3

# Остатки локальной LoRA-модели из более ранней итерации проекта -
# большие бинарники, пересоздаются скриптами из проекта lora_project
qwen-math-lora*/
*.pt
*.pth
*.bin
*.safetensors

# Python-кэш
__pycache__/
*.pyc

# Если когда-нибудь заведёшь .env файл для ключей вместо переменных
# окружения - тоже не должен попадать в git
.env
.env.local

# Логи, если решишь писать их в файл, а не только в консоль
*.log
